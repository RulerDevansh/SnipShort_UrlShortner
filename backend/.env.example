# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database (MySQL) ───────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=url_shortener
DB_USER=url_user
DB_PASSWORD=url_password

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=snipshort_production_secret_key_2026
JWT_EXPIRES_IN=7d

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ─── URLs ──────────────────────────────────────────────────
# Base URL used to build short links (no trailing slash)
BASE_URL=
# Frontend URL for OAuth redirect and CORS
FRONTEND_URL=

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SHORTEN_RATE_LIMIT_WINDOW_MS=60000
SHORTEN_RATE_LIMIT_MAX=10
